# Copy to deploy/.env and fill in values before `make deploy-up`.
# Docker Compose loads this file for variable substitution and service env.

# --- Compose project ---
COMPOSE_PROJECT_NAME=afi

# --- Postgres ---
POSTGRES_USER=afi
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=afi
# Host port mapped to container 5432 (change if 5432 is taken).
POSTGRES_HOST_PORT=5432

# --- Redis ---
REDIS_HOST_PORT=6379

# --- Published service ports ---
CONTROLPLANE_HOST_PORT=8081
GATEWAY_HOST_PORT=8080
WEB_HOST_PORT=3000

# --- AFI runtime (overrides YAML when set) ---
# Prefer setting secrets here rather than committing them in afi.yaml.
AFI_DATABASE_URL=postgres://afi:CHANGE_ME_db_password@postgres:5432/afi?sslmode=disable
AFI_REDIS_URL=redis://redis:6379/0
AFI_JWT_SECRET=CHANGE_ME_long_random_jwt_secret
AFI_INTERNAL_TOKEN=CHANGE_ME_long_random_internal_token
AFI_TOKEN_TTL=24h
AFI_CONTROLPLANE_ADDR=:8081
AFI_GATEWAY_ADDR=:8080
AFI_SNAPSHOT_POLL_INTERVAL=2s

# Encrypts Secrets UI credentials with storage_kind=encrypted_db (controlplane + gateway).
# AFI_CREDENTIALS_MASTER_KEY=change-me-long-random-string

# Platform domain events (optional)
AFI_EVENTS_OUTBOX_ENABLED=false
AFI_EVENTS_PUBLISHER=log
# AFI_EVENTS_NATS_URL=nats://nats:4222
# AFI_EVENTS_NATS_STREAM=AFI_PLATFORM
# AFI_EVENTS_NATS_SUBJECT_PREFIX=afi.platform
# AFI_EVENTS_KAFKA_BROKERS=kafka:9092
# AFI_EVENTS_KAFKA_TOPIC=afi.platform.events

# --- Upstream provider API keys (injected into the gateway process) ---
# Names must match each provider's api_key_env in the control plane / snapshot.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# OLLAMA_API_KEY=ollama-local

# --- Web UI build-time URLs (baked into static assets) ---
# Use URLs that browsers can reach (host ports / public hostnames), not Docker service names.
VITE_PLATFORM_API_URL=http://localhost:8081
VITE_GATEWAY_API_URL=http://localhost:8080
VITE_GATEWAY_API_KEY=

# --- Mail (org member invites) ---
AFI_MAIL_PUBLIC_APP_URL=http://localhost:3000
AFI_MAIL_FROM=AFI <noreply@afi.local>
AFI_MAIL_DEFAULT_PROVIDER=log
# AFI_MAIL_SMTP_ENABLED=true
# AFI_MAIL_SMTP_HOST=localhost
# AFI_MAIL_SMTP_PORT=1025
# AFI_MAIL_RESEND_ENABLED=true
# AFI_MAIL_RESEND_API_KEY=
