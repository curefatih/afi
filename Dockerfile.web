# syntax=docker/dockerfile:1
# Build the platform UI and serve static assets with nginx.

ARG NODE_VERSION=22

FROM node:${NODE_VERSION}-bookworm AS build
WORKDIR /src

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY web/package.json web/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY web/ ./

# Bake API endpoints into the static bundle (Vite). Override at build time.
ARG VITE_PLATFORM_API_URL=http://localhost:8081
ARG VITE_GATEWAY_API_URL=http://localhost:8080
ARG VITE_GATEWAY_API_KEY=
ENV VITE_PLATFORM_API_URL=$VITE_PLATFORM_API_URL \
	VITE_GATEWAY_API_URL=$VITE_GATEWAY_API_URL \
	VITE_GATEWAY_API_KEY=$VITE_GATEWAY_API_KEY

RUN pnpm build

FROM nginx:1.27-alpine AS runtime
COPY deploy/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
