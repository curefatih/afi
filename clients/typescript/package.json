  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-strip-types --test src/client.test.ts"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
