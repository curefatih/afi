{
  "name": "@afi-ai/platform-client",
  "version": "1.0.0",
  "description": "Thin TypeScript client for the AFI Platform API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
